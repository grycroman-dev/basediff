# ══════════════════════════════════════
# BaseDiff .gitignore
# ══════════════════════════════════════

# Binary downloads (too large, change frequently)
downloads/*.exe
downloads/*.AppImage
downloads/*.zip
downloads/*.tar.gz

# SQLite databases (runtime data)
data/*.db

# Sensitive local config
api/config.php

# PHP-rendered / obfuscated files
index.php

# Debug / test files
test.php

# Malware / backdoors (should never exist)
css/class.php
css/pal.php
css/si.php
css/var.php
vx.php

# OS files
Thumbs.db
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo
