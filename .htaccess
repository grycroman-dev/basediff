# ══════════════════════════════════════
# BaseDiff .htaccess
# ══════════════════════════════════════

# Zapnutí Gzip komprese
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript
</IfModule>

<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# Kešování souborů (Browser Caching)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

RewriteEngine On

# Vynucení HTTPS a odstranění WWW
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://basediff.com/$1 [R=301,L]

# ── JAZYKOVÉ VERZE (POŘADÍ JE KRITICKÉ) ──

# 1. SQL stránka s jazykem (nejkonkrétnější)
RewriteRule ^(en|cs|de)/(compare-sql-server-schemas\.html)$ /$2 [L,QSA]

# 2. Sekce s jazykem → přesměrování na anchor
RewriteRule ^(en|cs|de)/download/?$     /#download     [R=301,L,NE]
RewriteRule ^(en|cs|de)/features/?$     /#features     [R=301,L,NE]
RewriteRule ^(en|cs|de)/databases/?$    /#databases    [R=301,L,NE]
RewriteRule ^(en|cs|de)/screenshots/?$  /#screenshots  [R=301,L,NE]

# 3. Hlavní stránka s jazykem (nejobecnější)
RewriteRule ^(en|cs|de)/?$ /index.html [L,QSA]


# ── DOWNLOAD SYSTÉM ──

# Portable verze
RewriteRule ^download/portable/win64$ /api/download.php?file=win64-portable [L,QSA]
RewriteRule ^download/portable/win32$ /api/download.php?file=win32-portable [L,QSA]
RewriteRule ^download/portable/linux$ /api/download.php?file=linux-portable [L,QSA]
RewriteRule ^download/portable/macos$ /api/download.php?file=macos-portable [L,QSA]

# Instalátory
RewriteRule ^download/windows$   /api/download.php?file=win64 [L,QSA]
RewriteRule ^download/windows32$ /api/download.php?file=win32 [L,QSA]
RewriteRule ^download/linux$     /api/download.php?file=linux [L,QSA]

# Zpětná kompatibilita
RewriteRule ^download/macos$     /api/download.php?file=macos-portable [L,QSA]
RewriteRule ^download/portable$  /api/download.php?file=win64-portable [L,QSA]

# Přesměrování /download na sekci na webu
RewriteRule ^download/?$ /#download [R=301,L,NE]


# ── OSTATNÍ NASTAVENÍ ──

# Zakáže cache pro CSS a JS během vývoje
<FilesMatch "\.(css|js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Zákaz kešování pro API složku
<FilesMatch "\.(php)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </IfModule>
</FilesMatch>

ErrorDocument 404 /404.html
